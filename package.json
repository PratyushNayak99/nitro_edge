    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@nitrostack/cli": "^1",
    "@types/node": "^22.10.0",
    "typescript": "^5.3.3",
    "vitest": "^2.1.9"
  },
  "nitrostack": {
    "skillsVersion": "1.0.0"
  }
}
